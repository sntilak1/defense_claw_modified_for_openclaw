{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defenseclaw.dev/schemas/otel/runtime-llm-span.schema.json",
  "title": "DefenseClaw Runtime LLM Call Span",
  "description": "OTEL Span representing an LLM request/response lifecycle. Uses OTEL GenAI semantic conventions (gen_ai.* namespace). Emitted when OpenClaw hooks or the LLM gateway proxy capture LLM calls.",
  "type": "object",
  "required": ["name", "kind", "startTimeUnixNano", "attributes"],
  "properties": {
    "traceId": {
      "type": "string",
      "description": "16-byte hex trace ID."
    },
    "spanId": {
      "type": "string",
      "description": "8-byte hex span ID."
    },
    "parentSpanId": {
      "type": "string",
      "description": "Parent span ID (agent session span)."
    },
    "name": {
      "type": "string",
      "pattern": "^llm/.+$",
      "description": "Format: llm/{model_name}",
      "examples": ["llm/gpt-4", "llm/claude-sonnet-4-20250514", "llm/llama-3.1-70b"]
    },
    "kind": {
      "type": "integer",
      "const": 3,
      "description": "SPAN_KIND_CLIENT = 3 (calling an external LLM service)."
    },
    "startTimeUnixNano": {
      "type": "string",
      "description": "LLM request sent timestamp."
    },
    "endTimeUnixNano": {
      "type": "string",
      "description": "LLM response received timestamp."
    },
    "status": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "enum": [0, 1, 2]
        },
        "message": { "type": "string" }
      }
    },
    "attributes": {
      "type": "array",
      "items": { "$ref": "#/$defs/attribute" }
    }
  },
  "$defs": {
    "attribute": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "object" }
      }
    },
    "attributeDefinitions": {
      "type": "object",
      "description": "Semantic definition of all span attributes. gen_ai.* follows OTEL GenAI semantic conventions.",
      "properties": {
        "gen_ai.system": {
          "type": "string",
          "enum": ["openai", "anthropic", "nvidia-nim", "google", "cohere", "mistral"],
          "description": "LLM provider system identifier."
        },
        "gen_ai.request.model": {
          "type": "string",
          "description": "Model requested by the caller.",
          "examples": ["gpt-4", "claude-sonnet-4-20250514", "llama-3.1-70b-instruct"]
        },
        "gen_ai.response.model": {
          "type": "string",
          "description": "Actual model used (may differ from requested)."
        },
        "gen_ai.request.max_tokens": {
          "type": "integer",
          "description": "Max tokens parameter sent with the request."
        },
        "gen_ai.request.temperature": {
          "type": "number",
          "description": "Temperature parameter."
        },
        "gen_ai.response.finish_reasons": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Why the model stopped generating.",
          "examples": [["stop"], ["tool_use"], ["length"]]
        },
        "gen_ai.usage.prompt_tokens": {
          "type": "integer",
          "description": "Number of input/prompt tokens."
        },
        "gen_ai.usage.completion_tokens": {
          "type": "integer",
          "description": "Number of output/completion tokens."
        },
        "defenseclaw.llm.provider": {
          "type": "string",
          "description": "Provider identifier (may match gen_ai.system)."
        },
        "defenseclaw.llm.tool_calls": {
          "type": "integer",
          "description": "Number of tool_use blocks in the LLM response."
        },
        "defenseclaw.llm.guardrail": {
          "type": "string",
          "enum": ["none", "local", "ai-defense"],
          "description": "Which guardrail evaluated this LLM call."
        },
        "defenseclaw.llm.guardrail.result": {
          "type": "string",
          "enum": ["pass", "flagged", "blocked"],
          "description": "Guardrail evaluation outcome."
        }
      }
    }
  }
}
