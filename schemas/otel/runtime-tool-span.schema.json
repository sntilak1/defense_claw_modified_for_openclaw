{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defenseclaw.dev/schemas/otel/runtime-tool-span.schema.json",
  "title": "DefenseClaw Runtime Tool Call Span",
  "description": "OTEL Span representing a tool_call → tool_result lifecycle. Created on tool_call event, ended on matching tool_result.",
  "type": "object",
  "required": ["name", "kind", "startTimeUnixNano", "attributes"],
  "properties": {
    "traceId": {
      "type": "string",
      "description": "16-byte hex trace ID."
    },
    "spanId": {
      "type": "string",
      "description": "8-byte hex span ID."
    },
    "parentSpanId": {
      "type": "string",
      "description": "Parent span ID (LLM call span or agent session span)."
    },
    "name": {
      "type": "string",
      "pattern": "^tool/.+$",
      "description": "Format: tool/{tool_name}",
      "examples": ["tool/shell", "tool/read_file", "tool/web_search"]
    },
    "kind": {
      "type": "integer",
      "const": 1,
      "description": "SPAN_KIND_INTERNAL = 1"
    },
    "startTimeUnixNano": {
      "type": "string",
      "description": "tool_call event timestamp."
    },
    "endTimeUnixNano": {
      "type": "string",
      "description": "tool_result event timestamp."
    },
    "status": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "enum": [0, 1, 2],
          "description": "STATUS_CODE_UNSET=0, OK=1, ERROR=2. Set to ERROR when exit_code != 0."
        },
        "message": {
          "type": "string"
        }
      }
    },
    "attributes": {
      "type": "array",
      "items": { "$ref": "#/$defs/attribute" }
    },
    "events": {
      "type": "array",
      "description": "Span events, e.g. tool.flagged.",
      "items": {
        "$ref": "#/$defs/spanEvent"
      }
    }
  },
  "$defs": {
    "attribute": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "object" }
      }
    },
    "spanEvent": {
      "type": "object",
      "required": ["name", "timeUnixNano"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["tool.flagged"]
        },
        "timeUnixNano": { "type": "string" },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/attribute" }
        }
      }
    },
    "attributeDefinitions": {
      "type": "object",
      "description": "Semantic definition of all span attributes.",
      "properties": {
        "gen_ai.tool.name": {
          "type": "string",
          "description": "Tool name as reported by the agent framework.",
          "examples": ["shell", "read_file", "web_search"]
        },
        "defenseclaw.tool.status": {
          "type": "string",
          "description": "Status from the tool_call payload."
        },
        "defenseclaw.tool.args": {
          "type": "string",
          "description": "Truncated tool arguments JSON (max 2048 chars)."
        },
        "defenseclaw.tool.exit_code": {
          "type": "integer",
          "description": "Exit code from tool_result. 0 = success."
        },
        "defenseclaw.tool.output_length": {
          "type": "integer",
          "description": "Byte length of the tool_result output."
        },
        "defenseclaw.tool.dangerous": {
          "type": "boolean",
          "description": "True if the tool call matched a dangerous pattern."
        },
        "defenseclaw.tool.flagged_pattern": {
          "type": "string",
          "description": "The dangerous pattern that matched (if any).",
          "examples": ["curl", "rm -rf /", "base64 -d"]
        },
        "defenseclaw.tool.provider": {
          "type": "string",
          "enum": ["skill", "builtin", "mcp"],
          "description": "Where the tool comes from."
        },
        "defenseclaw.tool.skill_key": {
          "type": "string",
          "description": "Skill key if the tool is provided by a skill."
        }
      }
    },
    "spanEventAttributeDefinitions": {
      "type": "object",
      "description": "Attributes on tool.flagged span events.",
      "properties": {
        "defenseclaw.flag.reason": {
          "type": "string",
          "enum": ["dangerous-pattern"],
          "description": "Why the tool call was flagged."
        },
        "defenseclaw.flag.pattern": {
          "type": "string",
          "description": "The specific pattern that matched."
        }
      }
    }
  }
}
