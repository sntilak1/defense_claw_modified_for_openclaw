<dashboard version="1.1">
  <label>DefenseClaw Audit Activity</label>
  <description>Action, actor, target, and event-detail views for recent DefenseClaw activity.</description>
  <row>
    <panel>
      <title>Activity over time</title>
      <chart>
        <search>
          <query>`defenseclaw_audit_base` | timechart span=30m count</query>
          <earliest>-24h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="drilldown">none</option>
      </chart>
    </panel>
    <panel>
      <title>Top actions</title>
      <table>
        <search>
          <query>`defenseclaw_audit_base` | stats count by action | sort - count | head 15</query>
          <earliest>-24h</earliest>
          <latest>now</latest>
        </search>
        <option name="count">15</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Top actors</title>
      <table>
        <search>
          <query>`defenseclaw_audit_base` | stats count by actor | sort - count | head 15</query>
          <earliest>-24h</earliest>
          <latest>now</latest>
        </search>
        <option name="count">15</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
    <panel>
      <title>Top targets</title>
      <table>
        <search>
          <query>`defenseclaw_audit_base` | stats count by target | sort - count | head 15</query>
          <earliest>-24h</earliest>
          <latest>now</latest>
        </search>
        <option name="count">15</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Recent detailed events</title>
      <table>
        <search>
          <query>`defenseclaw_audit_base` | table timestamp action severity actor target details | sort - timestamp | head 50</query>
          <earliest>-24h</earliest>
          <latest>now</latest>
        </search>
        <option name="count">25</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
</dashboard>
